MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER=@your-bot:matrix.org
MATRIX_PASSWORD=your-password
# Or use an access token instead of password:
# MATRIX_ACCESS_TOKEN=syt_...
DATABASE_URL=sqlite+aiosqlite:///data/kleinanzeigen.db
CHECK_INTERVAL=600

# LLM evaluation (optional)
#LLM_PROVIDER=openai
#LLM_API_KEY=sk-...
#LLM_MODEL=gpt-4o-mini
#LLM_API_BASE=https://api.openai.com/v1

# Or use Ollama (local, no API key)
#LLM_PROVIDER=ollama
#LLM_MODEL=llama3.2
#LLM_API_BASE=http://localhost:11434

# Scrapingbee for leboncoin/antibot JS rendering (optional)
#SCRAPINGBEE_API_KEY=
